# Path to the sentinel YAML config.
# Defaults: /etc/sentinel/config.yaml in prod, ./config.yaml in dev.
SENTINEL_CONFIG_PATH=./config.yaml

# Set to 1 to serve fixture data without touching the Dataform API.
# Useful for local dev and screenshots. Ignored in production.
SENTINEL_MOCK=0

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Node env (next sets this automatically in dev/build)
NODE_ENV=development
